<%= form_for @task do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :details %>
    <%= f.text_field :details %>
  </div>

  <div>
    <% if Task.exists?(@task.id) %>
      <%= f.check_box :completed %>
      <p>Completed</p>
    <% end %>
  </div>

  <%= f.submit %>
<% end %>
